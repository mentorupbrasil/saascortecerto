generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  CLUBE
}

enum Role {
  SUPER_ADMIN
  OWNER
  MANAGER
  BARBER
  RECEPTIONIST
}

enum PaymentMethod {
  PIX
  CASH
  CARD
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum MembershipBilling {
  MONTHLY
  ONE_TIME
}

enum MembershipPlanType {
  MONTHLY_LIMITED
  MONTHLY_UNLIMITED
  VISIT_PACK
  LOYALTY
}

enum MembershipStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum WhatsAppMessageStatus {
  PENDING
  SENT
  FAILED
  SIMULATED
}

enum WhatsAppMessageType {
  RETURN
  CONFIRMATION
  REMINDER
  BIRTHDAY
  PROMOTION
  MANUAL
}

enum SubscriptionPaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum SignupCheckoutStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  EXPIRED
  CANCELLED
}

enum PublicBookingCheckoutStatus {
  PENDING_PAYMENT
  AWAITING_CONFIRMATION
  PAID
  EXPIRED
  CANCELLED
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  phone     String?
  address   String?
  plan      Plan     @default(FREE)
  active    Boolean  @default(true)
  billingEmail String?
  subscribedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  clients          Client[]
  services         Service[]
  appointments     Appointment[]
  settings         TenantSettings?
  membershipPlans  MembershipPlan[]
  clientMemberships ClientMembership[]
  whatsappMessages WhatsAppMessage[]
  subscriptionPayments SubscriptionPayment[]
  signupCheckout       SignupCheckout?
  publicBookingCheckouts PublicBookingCheckout[]
}

model SignupCheckout {
  id                      String               @id @default(cuid())
  status                  SignupCheckoutStatus @default(PENDING)
  plan                    Plan
  amount                  Decimal              @db.Decimal(10, 2)
  barbershopName          String
  slug                    String
  ownerName               String
  ownerEmail              String
  passwordHash            String
  phone                   String?
  mercadoPagoPreferenceId String?
  mercadoPagoPaymentId    String?
  tenantId                String?              @unique
  tenant                  Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  paidAt                  DateTime?
  expiresAt               DateTime?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@index([ownerEmail])
  @@index([status])
  @@index([mercadoPagoPreferenceId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(BARBER)
  active       Boolean  @default(true)
  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appointments Appointment[] @relation("BarberAppointments")

  @@index([tenantId])
}

model Client {
  id                  String    @id @default(cuid())
  tenantId            String
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                String
  phone               String
  birthday            DateTime?
  photoUrl            String?   @db.Text
  notes               String?
  lastVisitAt         DateTime?
  lastReturnMessageAt DateTime?
  returnDays          Int       @default(20)
  whatsappOptIn       Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  appointments  Appointment[]
  memberships   ClientMembership[]

  @@unique([tenantId, phone])
  @@index([tenantId])
}

model Service {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  price     Decimal  @db.Decimal(10, 2)
  duration  Int      @default(30)
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  appointments Appointment[]

  @@index([tenantId])
}

model Appointment {
  id            String            @id @default(cuid())
  tenantId      String
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client            @relation(fields: [clientId], references: [id])
  serviceId     String
  service       Service           @relation(fields: [serviceId], references: [id])
  barberId      String?
  barber        User?             @relation("BarberAppointments", fields: [barberId], references: [id])
  scheduledAt   DateTime
  duration      Int               @default(30)
  price         Decimal           @db.Decimal(10, 2)
  paymentMethod PaymentMethod?
  status        AppointmentStatus @default(SCHEDULED)
  notes         String?
  bookedOnline  Boolean           @default(false)
  membershipId  String?
  membership    ClientMembership? @relation(fields: [membershipId], references: [id])
  bookingCheckout PublicBookingCheckout?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([tenantId, scheduledAt])
  @@index([tenantId, status])
  @@index([barberId])
}

model TenantSettings {
  id                     String  @id @default(cuid())
  tenantId               String  @unique
  tenant                 Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  whatsappEnabled        Boolean @default(false)
  whatsappPhoneNumberId  String?
  whatsappAccessToken    String? @db.Text
  whatsappReturnTemplate String  @default("Fala {nome}! Já faz {dias} dias do seu último corte na {barbearia}. Bora marcar? Responda aqui que a gente agenda! ✂️")
  autoReturnEnabled      Boolean @default(false)
  returnMessageDays      Int     @default(20)
  lastBulkSendAt         DateTime?
  openTime               String  @default("08:00")
  closeTime              String  @default("20:00")
  workingDays            String  @default("1,2,3,4,5,6")
  publicBookingEnabled   Boolean @default(true)
  bookingNotifyPhone     String?
  bookingRequirePixPayment Boolean @default(false)
  bookingPixKey          String?
  bookingPixHolderName   String?
  bookingPixCity         String?  @default("SAO PAULO")
  mercadoPagoAccessToken String?  @db.Text
}

model PublicBookingCheckout {
  id                   String                      @id @default(cuid())
  tenantId             String
  tenant               Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status               PublicBookingCheckoutStatus @default(PENDING_PAYMENT)
  clientName           String
  clientPhone          String
  serviceId            String
  barberId             String?
  scheduledAt          DateTime
  amount               Decimal                     @db.Decimal(10, 2)
  mercadoPagoPaymentId String?
  appointmentId        String?                     @unique
  appointment          Appointment?                @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  expiresAt            DateTime
  paidAt               DateTime?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, scheduledAt])
  @@index([mercadoPagoPaymentId])
  @@index([expiresAt])
}

model WhatsAppMessage {
  id        String                @id @default(cuid())
  tenantId  String
  tenant    Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId  String?
  phone     String
  message   String                @db.Text
  type      WhatsAppMessageType   @default(RETURN)
  status    WhatsAppMessageStatus @default(PENDING)
  error     String?
  sentAt    DateTime?
  createdAt DateTime              @default(now())

  @@index([tenantId, createdAt])
  @@index([clientId])
}

model MembershipPlan {
  id                 String             @id @default(cuid())
  tenantId           String
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name               String
  description        String?            @db.Text
  price              Decimal            @db.Decimal(10, 2)
  billingCycle       MembershipBilling  @default(MONTHLY)
  planType           MembershipPlanType @default(MONTHLY_LIMITED)
  maxVisitsPerMonth  Int?
  totalVisits        Int?
  allowedWeekdays    String             @default("0,1,2,3,4,5,6")
  bonusAfterVisits   Int?
  bonusDescription   String?
  active             Boolean            @default(true)
  sortOrder          Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  memberships ClientMembership[]

  @@index([tenantId])
}

model ClientMembership {
  id                   String           @id @default(cuid())
  tenantId             String
  tenant               Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId             String
  client               Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  planId               String
  plan                 MembershipPlan   @relation(fields: [planId], references: [id])
  status               MembershipStatus @default(ACTIVE)
  startedAt            DateTime         @default(now())
  expiresAt            DateTime?
  periodStartAt        DateTime         @default(now())
  visitsUsedThisPeriod Int              @default(0)
  totalVisitsUsed      Int              @default(0)
  bonusEarned          Int              @default(0)
  notes                String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  appointments Appointment[]

  @@index([tenantId])
  @@index([clientId])
  @@index([status])
}

model SubscriptionPayment {
  id                   String                    @id @default(cuid())
  tenantId             String
  tenant               Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                 Plan
  amount               Decimal                   @db.Decimal(10, 2)
  status               SubscriptionPaymentStatus @default(PENDING)
  dueDate              DateTime
  paidAt               DateTime?
  tenantReportedPaidAt DateTime?
  notes                String?
  createdAt            DateTime                  @default(now())

  @@index([tenantId])
  @@index([status, dueDate])
}

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma db push --accept-data-loss && prisma generate && next build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/whatsapp-return",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/billing",
      "schedule": "0 6 * * *"
    }
  ]
}
